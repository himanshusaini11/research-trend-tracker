# =============================================================
# Python
# =============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# =============================================================
# Virtual environment — never commit this
# =============================================================
.venv/
venv/
env/

# =============================================================
# Environment variables — the most important one
# =============================================================
.env
.env.local
.env.*.local
!.env.example        # .env.example IS committed — it's a template

# =============================================================
# uv
# =============================================================
# uv.lock IS committed — it's your reproducibility guarantee
# pyproject.toml IS committed
.uv-cache/

# =============================================================
# Testing & coverage
# =============================================================
.coverage
.coverage.*
htmlcov/
.pytest_cache/
coverage.xml

# =============================================================
# Type checking
# =============================================================
.mypy_cache/
.dmypy.json

# =============================================================
# Linting
# =============================================================
.ruff_cache/

# =============================================================
# Docker
# =============================================================
*.log
docker-compose.override.yml

# =============================================================
# Airflow
# =============================================================
airflow/logs/
airflow/plugins/__pycache__/

# =============================================================
# IDE
# =============================================================
.vscode/settings.json    # personal VS Code settings — not project settings
.idea/
*.swp
*.swo

# =============================================================
# macOS
# =============================================================
.DS_Store
.AppleDouble
.LSOverride

# =============================================================
# AWS
# =============================================================
*.pem
.aws/

# =============================================================
# Jupyter (if used for exploration)
# =============================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================
# NOT ignored — these are intentionally committed
# =============================================================
# CLAUDE.md              — project instructions for Claude Code
# .claude/settings.json  — Claude Code permission rules
# uv.lock                — exact dependency versions
# .python-version        — pinned Python version
# .env.example           — secret template (no real values)