# Copy to .env and fill in real values

# App
APP_ENV=development
DEBUG=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rtt
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rtt

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Ollama / LLM
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# arXiv ingestion (JSON array)
ARXIV_CATEGORIES=["cs.AI","cs.LG","cs.CL","cs.CV","cs.NE","stat.ML","cs.IR","eess.SP","eess.IV"]
ARXIV_MAX_RESULTS_PER_FETCH=1000
ARXIV_FETCH_DELAY_SECONDS=3.0

# LLM extraction backend (ollama | anthropic-haiku | anthropic-sonnet)
EXTRACTION_BACKEND=ollama
ANTHROPIC_API_KEY=

# Graph analysis
GRAPH_TOP_N_CONCEPTS=200
GRAPH_CENTRALITY_K_SAMPLES=200

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BURST=10
