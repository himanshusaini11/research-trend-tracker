# Ingestion
ARXIV_MAX_RESULTS_PER_FETCH=500
ARXIV_FETCH_DELAY_SECONDS=3.0
ARXIV_CATEGORIES=["cs.AI","cs.LG","cs.CL","cs.CV","cs.NE","stat.ML","cs.IR","eess.SP","eess.IV"]

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BURST=10

# LLM
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:27b
OLLAMA_PREDICT_MODEL=qwen3.5:27b
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
OLLAMA_PREDICT_TIMEOUT_SECONDS=300
PREDICT_TOP_SIGNALS=20

# RAG Pipeline
EMBED_MODEL=mxbai-embed-large
EMBED_BATCH_SIZE=32
RAG_TOP_K=5
RAG_MIN_SCORE=0.3

# ARIS Simulation (v3.0.0)
SIMULATION_RAG_TOP_K=5
SIMULATION_RAG_MIN_SCORE=0.6
SIMULATION_MAX_ROUNDS=3
